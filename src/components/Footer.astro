---
import { licenseConfig, profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<div class="transition border-t border-[var(--line-divider)] mt-20"></div>
<div class="transition py-10 flex flex-col md:flex-row md:items-center justify-between gap-3">
    <div class="transition text-30 text-[0.8125rem]">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name} · 
        <a class="transition hover:text-[var(--primary)]" target="_blank" rel="license noopener" href={licenseConfig.url}>{licenseConfig.name}</a>
    </div>
    <div class="transition text-30 text-[0.8125rem] flex items-center gap-4">
        <a class="transition hover:text-[var(--primary)]" target="_blank" href={url('rss.xml')}>RSS</a>
        <a class="transition hover:text-[var(--primary)]" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a>
        <a class="transition hover:text-[var(--primary)]" target="_blank" href="https://astro.build">Astro</a>
    </div>
</div>
