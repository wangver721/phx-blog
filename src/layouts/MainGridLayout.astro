---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import type { MarkdownHeading } from "astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
} = Astro.props;
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar：贴纸面的极简导航 -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-50 pointer-events-none relative transition-all duration-700 w-full">
    <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar></Navbar>
    </div>
</div>

<!-- Main content：单栏编辑式排版，宽幅容器交由各页面自行约束阅读宽度 -->
<div class="absolute w-full z-30 pointer-events-none" style="top: 4.5rem">
    <div class="relative w-full pointer-events-auto">
        <div id="main-grid" class="transition duration-700 w-full max-w-[88rem] mx-auto px-6 md:px-10 lg:px-14">
            <main id="swup-container" class="transition-swup-fade w-full">
                <div id="content-wrapper" class="onload-animation">
                    <slot></slot>
                    <div class="footer onload-animation">
                        <Footer></Footer>
                    </div>
                </div>
            </main>
        </div>

        <BackToTop></BackToTop>
    </div>
</div>

<!-- TOC（仅超宽屏文章页显示） -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        {siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center"]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {!siteConfig.toc.enable && <div id="toc"></div>}
    </div>
</div>
</Layout>
