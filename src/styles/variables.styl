/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

/* ============ 极简编辑风设计系统 ============
   三色纪律：纸白 / 墨黑 / 一点赤红
   排版即视觉，无卡片、无玻璃、无阴影堆砌 */
:root
  --radius-large 0.75rem
  --content-delay 150ms
  --ease-smooth cubic-bezier(0.4, 0, 0.2, 1)
  /* 黑白切换的全局过渡时长 */
  --theme-duration 450ms

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  /* 赤红点缀色：浅色纸面用深红保证对比，暗色墨面用亮红 */
  --primary: oklch(0.55 0.19 var(--hue)) oklch(0.72 0.17 var(--hue))

  /* 纸白 / 墨黑 */
  --page-bg: oklch(0.982 0.002 var(--hue)) oklch(0.145 0.004 var(--hue))

  /* 编辑风：内容区块透明，排版自己说话 */
  --card-bg: transparent transparent

  --btn-content: oklch(0.40 0.01 var(--hue)) oklch(0.80 0.008 var(--hue))

  /* 中性灰按钮，不带彩度 */
  --btn-regular-bg: black(0.05) white(0.07)
  --btn-regular-bg-hover: black(0.08) white(0.11)
  --btn-regular-bg-active: black(0.12) white(0.15)

  --btn-plain-bg-hover: black(0.05) white(0.08)
  --btn-plain-bg-active: black(0.08) white(0.12)

  --btn-card-bg-hover: black(0.04) white(0.07)
  --btn-card-bg-active: black(0.08) white(0.11)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.16 0.004 var(--hue)) oklch(0.96 0.004 var(--hue))

  --title-active: oklch(0.45 0.17 var(--hue)) oklch(0.65 0.16 var(--hue))

  /* 发丝线：编辑排版的骨架 */
  --line-divider: black(0.09) white(0.11)

  --line-color: black(0.10) white(0.12)
  --meta-divider: black(0.22) white(0.24)

  /* 行内代码：中性灰底 */
  --inline-code-bg: black(0.055) white(0.09)
  --inline-code-color: oklch(0.35 0.01 var(--hue)) oklch(0.85 0.008 var(--hue))
  --selection-bg: oklch(0.88 0.06 var(--hue)) oklch(0.38 0.09 var(--hue))
  --codeblock-selection: oklch(0.40 0.08 var(--hue))
  --codeblock-bg: oklch(0.165 0.006 var(--hue)) oklch(0.185 0.006 var(--hue))
  --codeblock-topbar-bg: oklch(0.22 0.008 var(--hue)) oklch(0.24 0.008 var(--hue))

  --license-block-bg: black(0.03) white(0.05)

  --link-underline: black(0.20) white(0.25)
  --link-hover: black(0.06) white(0.10)
  --link-active: black(0.10) white(0.14)

  /* 浮层（搜索下拉/主题菜单）：实体纸面 + 发丝边 */
  --float-panel-bg: oklch(0.995 0.001 var(--hue)) oklch(0.19 0.005 var(--hue))

  --scrollbar-bg-light: black(0.3)
  --scrollbar-bg-hover-light: black(0.45)
  --scrollbar-bg-active-light: black(0.55)

  --scrollbar-bg-dark: white(0.3)
  --scrollbar-bg-hover-dark: white(0.45)
  --scrollbar-bg-active-dark: white(0.55)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.55 0.12 180) oklch(0.75 0.12 180)
  --admonitions-color-note: oklch(0.55 0.12 250) oklch(0.75 0.12 250)
  --admonitions-color-important: oklch(0.55 0.12 310) oklch(0.75 0.12 310)
  --admonitions-color-warning: oklch(0.60 0.12 60) oklch(0.75 0.12 60)
  --admonitions-color-caution: oklch(0.55 0.18 25) oklch(0.65 0.18 25)

  --toc-badge-bg: black(0.06) white(0.09)
  --toc-btn-hover: black(0.05) white(0.08)
  --toc-btn-active: black(0.08) white(0.12)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.55 0.19 var(--hue)) oklch(0.72 0.17 var(--hue))
})
