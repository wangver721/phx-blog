---
import path from "node:path";
import Comments from "@components/Comments.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	// URL 用 frontmatter.id 而不是文件名 slug，最终形如 /posts/1/、/posts/2/
	return blogEntries.map((entry) => ({
		params: { slug: String(entry.data.id) },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const { remarkPluginFrontmatter } = await entry.render();

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	// TODO include cover image here
};
---
<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={entry.data.lang} setOGTypeArticle={true} headings={headings}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <div class="max-w-[46rem] mx-auto pt-14 md:pt-20">
        <div id="post-container" class="relative w-full">
            <!-- 标题：编辑风大字 -->
            <div class="relative onload-animation mb-6">
                <h1
                    data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title"
                    class="transition w-full font-display font-bold
                    text-[2rem]/[1.35] md:text-[2.625rem]/[1.3] tracking-[0.005em]
                    text-black/90 dark:text-white/90"
                >
                    {entry.data.title}
                </h1>
            </div>

            <!-- 元信息：日期 · 字数 · 阅读时长 -->
            <div class="onload-animation flex items-center gap-2 text-50 text-sm mb-10 tabular-nums">
                <span>{formatDateToYYYYMMDD(entry.data.published)}</span>
                <span class="text-25">·</span>
                <span>{remarkPluginFrontmatter.words} {" " + i18n(I18nKey.wordsCount)}</span>
                <span class="text-25">·</span>
                <span>{remarkPluginFrontmatter.minutes} {" " + i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}</span>
                {entry.data.updated && entry.data.updated.getTime() !== entry.data.published.getTime() && (
                    <>
                        <span class="text-25">·</span>
                        <span>更新于 {formatDateToYYYYMMDD(entry.data.updated)}</span>
                    </>
                )}
            </div>

            <!-- 封面 -->
            {entry.data.image &&
                <ImageWrapper id="post-cover" src={entry.data.image} basePath={path.join("content/posts/", getDir(entry.id))} class="mb-10 rounded-xl banner-container onload-animation"/>
            }

            <Markdown class="mb-6 markdown-content onload-animation">
                <Content />
            </Markdown>

            {licenseConfig.enable && <License title={entry.data.title} slug={entry.slug} pubDate={entry.data.published} class="mb-6 rounded-xl license-container onload-animation"></License>}
        </div>

        <!-- 上一篇 / 下一篇 -->
        <div class="flex flex-col md:flex-row justify-between mt-4 mb-6 gap-3 overflow-hidden w-full onload-animation border-t border-[var(--line-divider)] pt-6">
            <a href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
               class:list={["group w-full md:w-1/2 overflow-hidden", {"pointer-events-none opacity-0": !entry.data.nextSlug}]}>
                {entry.data.nextSlug && <div class="w-full py-3 flex items-center !justify-start gap-3">
                    <Icon name="material-symbols:chevron-left-rounded" class="text-[1.5rem] text-50 group-hover:text-[var(--primary)] transition shrink-0" />
                    <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap font-medium text-75 group-hover:text-[var(--primary)]">
                        {entry.data.nextTitle}
                    </div>
                </div>}
            </a>

            <a href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
               class:list={["group w-full md:w-1/2 overflow-hidden", {"pointer-events-none opacity-0": !entry.data.prevSlug}]}>
                {entry.data.prevSlug && <div class="w-full py-3 flex items-center !justify-end gap-3">
                    <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap font-medium text-75 group-hover:text-[var(--primary)]">
                        {entry.data.prevTitle}
                    </div>
                    <Icon name="material-symbols:chevron-right-rounded" class="text-[1.5rem] text-50 group-hover:text-[var(--primary)] transition shrink-0" />
                </div>}
            </a>
        </div>

        <Comments />
    </div>
</MainGridLayout>
